# ==========================================
# 1. 基础镜像与版本配置
# ==========================================
OPENCLAW_IMAGE=your-docker-image
OPENCLAW_VERSION=2026.2.24      #可自己修改

# ==========================================
# 2. 构建期网络代理 (可选)
# ==========================================
BUILD_HTTP_PROXY=
BUILD_HTTPS_PROXY=

# ==========================================
# 3. 运行期网络代理 (可选)
# ==========================================
OPENCLAW_RUNTIME_HTTP_PROXY=
OPENCLAW_RUNTIME_HTTPS_PROXY=
OPENCLAW_RUNTIME_NO_PROXY=localhost,127.0.0.1

# ==========================================
# 4. 目录挂载与端口配置
# ==========================================
OPENCLAW_CONFIG_DIR=./data
OPENCLAW_WORKSPACE_DIR=./data/workspace
OPENCLAW_GATEWAY_PORT=18789
OPENCLAW_BRIDGE_PORT=18790
OPENCLAW_GATEWAY_BIND=127.0.0.1